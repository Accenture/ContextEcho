{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextEcho donation manifest",
  "type": "object",
  "required": ["agent", "model", "org", "turns", "records", "compactions", "privacy_tier"],
  "properties": {
    "contributor": {"type": ["string", "null"]},
    "credit_name": {"type": ["string", "null"]},
    "contributor_institute": {"type": ["string", "null"]},
    "agent": {"type": "string"},
    "model": {"type": "string"},
    "org": {"type": "string"},
    "records": {"type": ["integer", "string"]},
    "turns": {"type": ["integer", "string"]},
    "compactions": {"type": ["integer", "string"]},
    "privacy_tier": {"type": "string", "enum": ["full_redacted", "user_minimized"]},
    "allowed_uses": {"type": "array", "items": {"type": "string"}},
    "disallowed_uses": {"type": "array", "items": {"type": "string"}},
    "source_format": {"type": ["string", "null"]},
    "submitted_utc": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
